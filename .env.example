APP_NAME=Spotify Backend API
API_PREFIX=/api
DEBUG=false
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=postgresql+asyncpg://postgres:admin123@localhost:5432/spotify_backend
# Deploy: run `alembic upgrade head` against this URL before first app start (indexes + schema).
# Performance: keep Postgres and Redis in the same cloud region as the API (lower RTT than colocating only the app).
# Optional: enables HTTP response caching for many GET routes + search cache (strongly recommended in production).
# REDIS_URL=redis://localhost:6379/0
# Search cache TTL in seconds (default 300 when unset in code).
# SEARCH_REDIS_TTL_SECONDS=300
# Log WARNING "slow_request" when a request exceeds this many ms (default 500). Raise (e.g. 1200) to reduce log noise over WAN/Neon.
# SLOW_REQUEST_MS=500
ITUNES_BASE_URL=https://itunes.apple.com
ITUNES_COUNTRY=tr
MUSIC_DIR=music
ALLOW_STREAM_QUERY_TOKEN=true
UI_BASE_URL=http://localhost:8010/ui
# Optional: comma-separated extra CORS origins (Netlify deploy previews, second domain).
# CORS_EXTRA_ORIGINS=https://branch--yourapp.netlify.app
# Set to false to disable regex matching for all https://*.netlify.app (default true).
# CORS_ALLOW_NETLIFY_PREVIEWS=true
PASSWORD_RESET_EXPIRE_MINUTES=30
# Production (Railway): use Resend over HTTPS — outbound SMTP is often blocked.
# RESEND_API_KEY=re_xxxxxxxx
# One line, no line break in the middle: onboarding@resend.dev (not "onboarding@" + newline).
# onboarding@resend.dev only delivers to your Resend account email until you verify a domain.
# RESEND_FROM_EMAIL=onboarding@resend.dev
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true
